# 无限画布 · Git 忽略规则

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
.venv/
*.egg
*.so

# 环境变量（含 API Key，绝不提交）
.env
.env.local
.env.*.local

# 运行时日志
*.log
*.err
*.out

# 测试产物
test_img*.png
e2e_*.png
chain_result.txt
_check_out.txt

# ComfyUI 运行时数据
agent/comfy_output/
agent/templates/user/

# Node
frontend/node_modules/
frontend/dist/
frontend/*.tsbuildinfo
frontend/vite.config.d.ts
frontend/vite.config.js

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# 临时构建输出
ui_*.png
ui_nodes.mjs
