# 无限画布 · Agent 环境变量模板
# 复制为 .env 并填入实际值（.env 已在 .gitignore 中忽略，不会被提交）

# DeepSeek API（主 LLM，意图解析）
DEEPSEEK_API_KEY=sk-你的API密钥
DEEPSEEK_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Ollama 本地 LLM（离线兜底，可选）
OLLAMA_URL=http://127.0.0.1:11434

# ComfyUI 生图引擎（必填）
COMFYUI_URL=http://127.0.0.1:8188

# 共享模型库路径（可选，给 env_check.py 做模型文件校验）
# 示例：C:\ai_comfyui_dd\models
SHARED_MODEL_LIB=

# 输出文件保留天数（默认 30 天）
OUTPUT_RETENTION_DAYS=30
